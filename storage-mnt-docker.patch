     state: present
   tags: moodle
 
+# H5P core content (mod_h5pactivity) ships in Moodle itself since 3.9 and
+# should already be available in "Add an activity" with no extra work.
+# Only run this (ansible-playbook site.yml --tags h5p) if you specifically
+# want the older community mod_hvp plugin instead — e.g. for h5p.org Hub
+# browsing or resumable content state. Moodle's own docs recommend NOT
+# running both side by side. The 'never' tag means these are skipped on
+# normal runs and only execute when h5p is explicitly requested.
+- name: Check if H5P (mod_hvp) plugin is already installed
+  ansible.builtin.stat:
+    path: "{{ docker_data_root }}/moodle/html/mod/hvp/version.php"
+  register: h5p_plugin_installed
+  tags: [h5p, never]
+
+- name: Install H5P (mod_hvp) plugin via Moosh
+  community.docker.docker_container_exec:
+    container: moodle
+    command: moosh plugin-install mod_hvp
+  register: h5p_install
+  failed_when: false
+  when: not h5p_plugin_installed.stat.exists
+  tags: [h5p, never]
+
+- name: Retry H5P plugin install (known Moosh first-run issue, see erseco/alpine-moodle docs)
+  community.docker.docker_container_exec:
+    container: moodle
+    command: moosh plugin-install --delete mod_hvp
+  when:
+    - not h5p_plugin_installed.stat.exists
+    - h5p_install.rc != 0
+  tags: [h5p, never]
+
