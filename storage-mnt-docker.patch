 # group_vars/all/vars.yml
+
+# Single source of truth for where persistent container data lives.
+# This is the drive your admin mounts at /mnt/docker (/dev/sdb1) —
+# everything under here is what gets backed up, and restoring it to
+# a fresh host + `docker compose up` should fully reconstitute state.
+docker_data_root: /mnt/docker
+
 moodle_admin_user: "{{ vault_moodle_admin_user }}"
 moodle_admin_password: "{{ vault_moodle_admin_password }}"
 moodle_db_password: "{{ vault_moodle_db_password }}"
