-- name: Create app directories
+- name: Check whether {{ docker_data_root }} is a mounted filesystem
+  ansible.builtin.command: mountpoint -q "{{ docker_data_root }}"
+  register: docker_data_root_mount
+  changed_when: false
+  failed_when: false
+  tags: always
+
+- name: Abort if the data drive is not mounted at {{ docker_data_root }}
+  ansible.builtin.fail:
+    msg: >-
+      {{ docker_data_root }} is not currently a mount point. Refusing to
+      continue, because container data would silently be written to the
+      OS disk instead of the data drive (/dev/sdb1). Mount the data drive
+      at {{ docker_data_root }} first, then re-run this playbook.
+  when: docker_data_root_mount.rc != 0
+  tags: always
+
+- name: Create app config directories (reproducible, live on OS disk)
+  file:
