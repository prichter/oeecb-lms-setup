version: '3.8'

services:
  moodle-db:
    image: postgres:16-alpine
    container_name: moodle-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ vault_moodle_db_name }}
      POSTGRES_USER: {{ vault_moodle_db_user }}
      POSTGRES_PASSWORD: {{ vault_moodle_db_password }}
    volumes:
      - {{ docker_data_root }}/moodle/db:/var/lib/postgresql/data
    networks:
      - moodle_net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ vault_moodle_db_user }} -d {{ vault_moodle_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

  moodle:
    image: erseco/alpine-moodle
    container_name: moodle
    restart: unless-stopped
    depends_on:
      moodle-db:
        condition: service_healthy
    environment:
      SITE_URL: https://{{ moodle_hostname }}
      REVERSEPROXY: "true"
      SSLPROXY: "true"
      DB_TYPE: pgsql
      DB_HOST: moodle-db
      DB_PORT: 5432
      DB_NAME: {{ vault_moodle_db_name }}
      DB_USER: {{ vault_moodle_db_user }}
      DB_PASS: {{ vault_moodle_db_password }}
      MOODLE_SITENAME: {{ moodle_sitename }}
      MOODLE_USERNAME: {{ vault_moodle_admin_user }}
      MOODLE_PASSWORD: {{ vault_moodle_admin_password }}
      MOODLE_EMAIL: {{ vault_moodle_admin_email }}
    volumes:
      - {{ docker_data_root }}/moodle/moodledata:/var/www/moodledata
      - {{ docker_data_root }}/moodle/html:/var/www/html
    networks:
      - moodle_net
      - proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.moodle.rule=Host(`{{ moodle_hostname }}`)"
      - "traefik.http.routers.moodle.entrypoints=websecure"
      - "traefik.http.routers.moodle.tls=true"
      - "traefik.http.services.moodle.loadbalancer.server.port=8080"
      - "traefik.http.routers.moodle.middlewares=moodle-headers"
      - "traefik.http.middlewares.moodle-headers.headers.customrequestheaders.X-Forwarded-Proto=https"

networks:
  moodle_net:
    driver: bridge
  proxy:
    external: true